# Copy to .env.production after registering a SMART app on your OpenEMR.
#
# To register, run:
#
#   curl -sk -X POST -H 'Content-Type: application/json' \
#     https://YOUR_HOST/oauth2/default/registration \
#     --data '{
#       "application_type": "private",
#       "redirect_uris": ["https://YOUR_HOST/dashboard/callback"],
#       "client_name": "OpenEMR Patient Dashboard (React)",
#       "token_endpoint_auth_method": "client_secret_post",
#       "scope": "openid offline_access launch/patient patient/Patient.read patient/AllergyIntolerance.read patient/Condition.read patient/MedicationRequest.read patient/CareTeam.read patient/Encounter.read"
#     }'
#
# Then approve the client at:
#   https://YOUR_HOST/interface/main/main_screen.php?auth=login&site=default
#   → Admin → System → API Clients → enable the client
#
VITE_OAUTH_CLIENT_ID=
VITE_OAUTH_CLIENT_SECRET=
